<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STORMFIRE</title>

<style>
body{
    margin:0;
    font-family:Arial, sans-serif;
    background: radial-gradient(circle at top, #1a1a1a, #000);
    color:white;
    text-align:center;
}

header{
    padding:40px 20px;
}

.logo{
    width:300px;
    max-width:90%;
}

h1{
    font-size:48px;
    background:linear-gradient(90deg,#ff7a00,#ff0000,#00aaff);
    -webkit-background-clip:text;
    color:transparent;
}

.download-btn{
    display:inline-block;
    margin:20px;
    padding:15px 40px;
    font-size:20px;
    background:linear-gradient(90deg,#ff7a00,#ff0000);
    border:none;
    border-radius:8px;
    color:white;
    text-decoration:none;
    transition:0.3s;
}

.download-btn:hover{
    transform:scale(1.05);
}

.section{
    padding:50px 20px;
}

.card{
    background:#111;
    margin:15px auto;
    padding:20px;
    border-radius:10px;
    max-width:600px;
}

footer{
    margin-top:50px;
    padding:20px;
    background:#111;
    font-size:14px;
}
</style>
</head>

<body>

<header>
    <img src="logo.png" class="logo">
    <h1>STORMFIRE</h1>
    <a href="#" class="download-btn">Launcher herunterladen</a>
</header>

<div class="section">
    <h2>News</h2>
    <div class="card">
        <h3>Version 0.1</h3>
        <p>Closed Alpha gestartet 🔥</p>
    </div>
</div>

<div class="section">
    <h2>PvP Rangliste</h2>
    <div class="card">#1 Spieler – 2400 Rating</div>
    <div class="card">#2 Spieler – 2200 Rating</div>
    <div class="card">#3 Spieler – 2100 Rating</div>
    <div class="card">#4 Spieler – 2000 Rating</div>
    <div class="card">#5 Spieler – 1900 Rating</div>
</div>

<div class="section">
    <h2>Statistiken</h2>
    <div class="card">Meiste Damage: 9.452.331</div>
    <div class="card">Meistes Gold: 42.991</div>
    <div class="card">Meiste Spielzeit: 312 Stunden</div>
</div>

<footer>
    © 2026 Denis Toni Güven – Alle Rechte vorbehalten  
    <br>
    Impressum folgt
</footer>

</body>
</html>
